#!/usr/bin/env bash

# Directory dei file .desktop
DIRS=(
    "$HOME/.local/share/applications"
    "/usr/share/applications"
)

# File temporaneo
TMP=$(mktemp)

# Estrai Nome e Exec
for dir in "${DIRS[@]}"; do
    [ -d "$dir" ] || continue
    for file in "$dir"/*.desktop; do
        [ -f "$file" ] || continue

        name=$(grep -m1 '^Name=' "$file" | cut -d'=' -f2-)
        exec=$(grep -m1 '^Exec=' "$file" | cut -d'=' -f2-)

        # Rimuove placeholder tipo %U %f ecc.
        # exec_clean="${exec//*%[fFuUdDnNickvm]/}"
        # exec_clean=$(echo "$exec" | sed 's/ *%[fFuUdDnNickvm]//g')
        exec_clean=${exec//%?/}
        exec_clean=${exec_clean//  / }
        exec_clean=${exec_clean## }
        exec_clean=${exec_clean%% }

        if [ -n "$name" ] && [ -n "$exec_clean" ]; then
            echo "$name|$exec_clean" >> "$TMP"
        fi
    done
done

# Menu con bemenu
choice=$(cut -d'|' -f1 "$TMP" | sort -u | bemenu -i -p "Run:")

# Trova comando associato
cmd=$(grep "^$choice|" "$TMP" | head -n1 | cut -d'|' -f2-)

# Esegui
if [ -n "$cmd" ]; then
    setsid bash -c "$cmd" >/dev/null 2>&1 &
fi

rm "$TMP"

